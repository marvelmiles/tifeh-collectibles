# ── Tifeh Collectibles · environment variables ─────────────────────────────
# Copy this file to ".env" and fill in your values, then restart the dev server.
# All client-exposed variables MUST be prefixed with VITE_.

# Contact form provider. Options: "formspree" | "emailjs" | "demo"
# "demo" simulates a successful send (no email is delivered) — useful for local dev.
VITE_FORM_PROVIDER=demo

# ── Formspree (https://formspree.io) ───────────────────────────────────────
# Create a form and paste its endpoint, e.g. https://formspree.io/f/abcdwxyz
VITE_FORMSPREE_ENDPOINT=

# ── EmailJS (https://www.emailjs.com) ──────────────────────────────────────
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
